---
import OldWebLayout from '@/layouts/OldWebLayout.astro';
import SleepNetDirectory from '@/components/sleepnet/SleepNetDirectory';
import FakeAdStrip from '@/components/ads/FakeAdStrip.astro';
---
<OldWebLayout title="SleepNet" section="sleepnet">
  <div class="status-strip"><span>sleepnet</span><span>search bad pages</span><span>old web portal</span><span>sleepnet:// URLs</span></div>
  <h1>SleepNet</h1>
  <p class="tagline-block">The hidden internet under the internet. Search fake companies, strange pages, public files, food court ventures, object archives, and whatever the directory failed to remove.</p>

  <FakeAdStrip limit={4} label="Printer-Friendly Sponsors / Do Not Trust" />

  <SleepNetDirectory client:load />
</OldWebLayout>
