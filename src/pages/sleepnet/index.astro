---
import OldWebLayout from '@/layouts/OldWebLayout.astro';
import SleepNetDirectory from '@/components/sleepnet/SleepNetDirectory';
import LinkMaze from '@/components/oldweb/LinkMaze.astro';
---
<OldWebLayout title="SleepNet Directory" section="sleepnet">
  <div class="status-strip"><span>sleepnet directory</span><span>searchable URLs</span><span>not a feed</span><span>pages after the internet closes</span></div>
  <h1>SleepNet</h1>
  <p class="tagline-block">Search the hidden internet inside The Breakroom. Faux companies, object archives, motel pages, personal shrines, and small websites that should have stayed in the drawer.</p>

  <SleepNetDirectory client:load />

  <LinkMaze title="SleepNet entry points" notice="Every published page gets a normal URL and an in-world SleepNet URL." links={[
    { href: '/sleepnet/create', label: 'Create SleepNet Page', note: 'start with a faux company', stamp: 'BUILD' },
    { href: '/locker', label: 'Locker', note: 'your Regular File owns the weird pages' },
    { href: '/regulars/regular', label: 'Regular Files', note: 'identity before creation' },
    { href: '/artifacts', label: 'Artifacts', note: 'evidence you can attach later', stamp: 'FILED' }
  ]} />
</OldWebLayout>
