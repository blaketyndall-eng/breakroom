---
import OldWebLayout from '@/layouts/OldWebLayout.astro';
import SleepNetSearchV2 from '@/components/sleepnet/SleepNetSearchV2';
import LotWeatherWidget from '@/components/sleepnet/LotWeatherWidget';
import SiteOfTheNight from '@/components/sleepnet/SiteOfTheNight';
import RecentlyIndexed from '@/components/sleepnet/RecentlyIndexed';
import DirectoryCategories from '@/components/sleepnet/DirectoryCategories';
import RadioStatusWidget from '@/components/sleepnet/RadioStatusWidget';
import MoreLikeThis from '@/components/sleepnet/MoreLikeThis';
import FakeAdStrip from '@/components/ads/FakeAdStrip.astro';
import { getPortalData } from '@/lib/sleepnetPortal';

const portalData = await getPortalData();
---
<OldWebLayout title="SleepNet" section="sleepnet">
  <div class="status-strip"><span>sleepnet</span><span>after-hours portal</span><span>old web directory</span><span>clock reads 1:47</span></div>

  <div class="sleepnet-portal-header">
    <h1>SleepNet</h1>
    <p class="tagline-block">The after-hours internet. Search fake companies, strange pages, classified boards, object archives, and whatever the directory failed to remove.</p>
  </div>

  <!-- Search V2 — multi-source, tabbed, personalized -->
  <SleepNetSearchV2 client:load />

  <FakeAdStrip limit={3} label="Printer-Friendly Sponsors / Do Not Trust" />

  <!-- Portal widget grid — mix of static (SSR) and interactive (client:idle) -->
  <div class="sleepnet-portal-grid">
    <div class="portal-col portal-col-main">
      <SiteOfTheNight site={portalData.siteOfTheNight} />
      <RecentlyIndexed sites={portalData.recentlyIndexed} />
      <DirectoryCategories categories={portalData.directoryCategories} />
    </div>
    <div class="portal-col portal-col-side">
      <LotWeatherWidget client:idle />
      <RadioStatusWidget />
      <MoreLikeThis client:idle />
    </div>
  </div>

  <FakeAdStrip limit={2} label="Bottom Sponsors / Possibly Expired" />

  <footer class="sleepnet-portal-footer">
    <p>SleepNet is an OmniShift property. Acquired during a meeting nobody remembers. All pages indexed without consent. Some pages are missing on purpose.</p>
    <p>Visitor count: <span class="visitor-counter">00{Math.floor(Math.random() * 900 + 100)}</span></p>
  </footer>
</OldWebLayout>

<style>
  .sleepnet-portal-header {
    margin-bottom: 1.5rem;
  }
  .sleepnet-portal-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  @media (max-width: 860px) {
    .sleepnet-portal-grid {
      grid-template-columns: 1fr;
    }
  }
  .portal-col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .sleepnet-portal-footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border, #444);
    font-size: 0.85rem;
    opacity: 0.7;
  }
  .visitor-counter {
    font-family: var(--type-mono, monospace);
    background: var(--color-surface, #1a1a1a);
    padding: 0.1em 0.4em;
    border: 1px inset;
  }
</style>
