---
import OldWebLayout from '@/layouts/OldWebLayout.astro';
---
<OldWebLayout title="page missing" section="voidshell">
  <div class="status-strip">
    <span>void</span>
    <span>directory changed its mind</span>
    <span>not your fault</span>
    <span><a href="/void">return to portal</a></span>
  </div>

  <h1>The directory changed its mind.</h1>

  <p class="tagline-block">
    Some pages are missing on purpose. Some pages are missing on accident.
    The directory does not distinguish. Try a different door.
  </p>

  <section class="old-shell">
    <div class="old-header">Doors that probably still work</div>
    <div class="old-body">
      <ul>
        <li><a href="/void">/void</a> — VOID home</li>
        <li><a href="/locker">/locker</a> — your Regular File</li>
        <li><a href="/stuff">/stuff</a> — Stuff drawer</li>
        <li><a href="/sign-the-wall">/sign-the-wall</a> — the wall</li>
        <li><a href="/districts">/districts</a> — geography of the underground</li>
        <li><a href="/radio">/radio</a> — Radio 1:47</li>
        <li><a href="/phone">/phone</a> — phone behind the bar</li>
      </ul>
    </div>
  </section>

  <p class="memo-box">
    A door moved.
  </p>
</OldWebLayout>
