---
/**
 * /idle-hands/player/[slug] — player bio (V3 redesign).
 *
 * Mirrors the parent /idle-hands chrome (`ihp-*`) at smaller scale.
 * The bio reads as a paper card filed in The Cue's regulars binder.
 *
 * Runtime SSR pattern matching the rest of the app's dynamic routes.
 */
import OldWebLayout from '@/layouts/OldWebLayout.astro';

const players = [
  'Nun Dog','Mugsy Late Again','The Driver','Miss September',
  'Coffee','The Kid With The Mop','House Money','Motel 8',
  'Gold Grill','Clock Dispute','Soft Break Steve','Applause Money',
];

export const prerender = false;

const slug = Astro.params.slug ?? '';
const name = players.find((p) => p.toLowerCase().replaceAll(' ', '-') === slug);
---
{name ? (
  <OldWebLayout title={`${name} / Player Bio`} section="idlehands">
    <section class="ihp-page">
      <a href="/idle-hands" class="ihp-bio-back">&larr; Back to Idle Hands</a>
      <article class="ihp-bio-card">
        <p class="ihp-bio-eyebrow">Player Bio · Regular's rundown</p>
        <h1 class="ihp-bio-name">{name}</h1>
        <dl class="ihp-bio-meta">
          <dt>Known for</dt><dd>Playing better after the first bad call.</dd>
          <dt>Last seen</dt><dd>Near the table light, refusing to explain the score.</dd>
          <dt>Signature object</dt><dd>Cue chalk in a jewelry box.</dd>
          <dt>Filed under</dt><dd>{slug}</dd>
        </dl>
        <p class="ihp-bio-note">
          Has a face people remember. Especially after the room gets quiet.
          — The Cue
        </p>
        <span class="ihp-bio-stamp">RISK / UNVERIFIED</span>
      </article>
      <footer class="ihp-footer">
        <p class="ihp-footer-meta">Filed: {slug} · paper copy retained · photocopy quality not guaranteed</p>
        <a class="ihp-footer-back" href="/idle-hands">&larr; back to roster</a>
      </footer>
    </section>
  </OldWebLayout>
) : (
  <OldWebLayout title="Unknown Player / Idle Hands" section="idlehands">
    <section class="ihp-page">
      <a href="/idle-hands" class="ihp-bio-back">&larr; Back to Idle Hands</a>
      <article class="ihp-bio-card">
        <p class="ihp-bio-eyebrow">Player Bio · Not on the wall</p>
        <p class="ihp-bio-missing">No player named “{slug}” appears in the regulars’ rundown. Names get filed wrong sometimes.</p>
      </article>
    </section>
  </OldWebLayout>
)}
