---
import OldWebLayout from '@/layouts/OldWebLayout.astro';
import TableBox from '@/components/oldweb/TableBox.astro';
const players = ['Nun Dog','Mugsy Late Again','The Driver','Miss September','Coffee','The Kid With The Mop','House Money','Motel 8','Gold Grill','Clock Dispute','Soft Break Steve','Applause Money'];
---
<OldWebLayout title="Idle Hands Invitational" section="idlehands">
  <div class="status-strip"><span>poolhall.sleeper.net</span><span>Race to 7</span><span>Cash only</span><span>Clock optional</span></div>
  <h1>IDLE HANDS INVITATIONAL</h1>
  <p>Old school pool tournament page. It may be real, old, upcoming, AI-generated, recurring, or a ritual. Late registration accepted. Probably.</p>
  <div class="grid-2">
    <TableBox title="Tournament Status">
      <table class="table-box">
        <tr><th>Status</th><td>Unresolved</td></tr>
        <tr><th>Doors</th><td>If they exist, open at 7:30 PM</td></tr>
        <tr><th>Pot</th><td>$20 cash / no cards / applause not accepted</td></tr>
        <tr><th>Current time</th><td>1:47 AM</td></tr>
      </table>
    </TableBox>
    <TableBox title="Register">
      <p>Registration creates your After Hours Persona.</p>
      <form>
        <input placeholder="alias, or leave blank" style="width:100%;padding:10px;margin-bottom:8px;" />
        <select style="width:100%;padding:10px;margin-bottom:8px;"><option>Take Interview</option><option>I Don't Care</option></select>
        <button class="old-button" type="button">Generate Persona</button>
      </form>
    </TableBox>
  </div>
  <TableBox title="Roster / Long-time regular rundown">
    <div class="grid-3">
      {players.map((p, i) => <article class="memo-box"><h2><a href={`/idle-hands/player/${p.toLowerCase().replaceAll(' ','-')}`}>{p}</a></h2><p>Handicap: {i % 7 + 2}. Known for showing up when the light gets bad.</p></article>)}
    </div>
  </TableBox>
  <TableBox title="House Rules">
    <ol>
      <li>House rules apply.</li><li>No soft hands.</li><li>Call your own fouls.</li><li>If you argue a call, we laugh.</li><li>Tip the bartender.</li><li>Don’t be an ass.</li>
    </ol>
  </TableBox>
</OldWebLayout>
