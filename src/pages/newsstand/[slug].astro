---
import OldWebLayout from '@/layouts/OldWebLayout.astro';
import { BREAKROOM_DATA } from '@/content/data/breakroom';
import { slugify } from '@/lib/slug';
import { getPublicNewsItemBySlug } from '@/lib/publicContent';

type NewsstandItem = {
  t?: string;
  head?: string;
  k?: string;
  b?: string;
  body?: string;
  byline?: string;
};

type NewsstandGroup = [string, NewsstandItem[]];

const groups = Object.entries(BREAKROOM_DATA.headlines) as NewsstandGroup[];
const staticEntries = groups.flatMap(([group, items]) =>
  items.map((item) => {
    const title = item.t ?? item.head ?? 'Untitled Notice';
    return {
      slug: slugify(title),
      group,
      title,
      body: item.k ?? item.b ?? item.body ?? 'No further information was provided.',
      byline: item.byline ?? 'STAFF / 1:47 A.M.',
    };
  })
);

export function getStaticPaths() {
  return staticEntries.map((entry) => ({ params: { slug: entry.slug } }));
}

const { slug } = Astro.params;
const result = await getPublicNewsItemBySlug(slug ?? '');
const entry = result.item;

if (!entry) {
  return Astro.redirect('/newsstand');
}
---
<OldWebLayout title={`${entry.title} / Newsstand`} section="newsstand">

  <!-- Ticker -->
  <div class="ns-ticker">
    <span>SLEEPNEWS</span>
    <span>ARTICLE</span>
    <span>source: {result.source}</span>
  </div>

  <!-- Masthead (compact on article pages) -->
  <div class="ns-masthead" style="padding:10px 0 8px;">
    <h1 style="font-size:clamp(28px,6vw,48px);"><a href="/newsstand" style="color:var(--ink);text-decoration:none;">Sleep<span class="ns-red">News</span></a></h1>
  </div>

  <!-- Back link -->
  <a class="ns-back" href="/newsstand">← Back to SleepNews</a>

  <!-- Article -->
  <article class="ns-article">
    <div class="ns-article-meta">{entry.category} / {entry.byline} / source: {result.source}</div>
    {result.error && <p class="ns-notice" style="padding:6px 0;">Public news detail fallback active: {result.error}</p>}
    <h1>{entry.title}</h1>
    <p class="ns-body">{entry.body}</p>
    <p class="ns-note">The source could not be reached for comment. The room declined to answer because it was busy being a room.</p>
  </article>

  <!-- Footer -->
  <div class="ns-footer">
    <p><a href="/newsstand">← Return to SleepNews</a> / <a href="/after-hours">Back to room</a></p>
  </div>

</OldWebLayout>
