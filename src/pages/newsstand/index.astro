---
import OldWebLayout from '@/layouts/OldWebLayout.astro';
import TableBox from '@/components/oldweb/TableBox.astro';
import LinkMaze from '@/components/oldweb/LinkMaze.astro';
import { getPublicNewsItems, groupNewsItems } from '@/lib/publicContent';

const newsItems = await getPublicNewsItems();
const groups = Object.entries(groupNewsItems(newsItems.items));
---
<OldWebLayout title="3AM Edition / Newsstand" section="newsstand">
  <div class="status-strip"><span>3AM EDITION</span><span>printer friendly</span><span>archive corrupted</span><span>weather: fluorescent</span><span>source: {newsItems.source}</span></div>
  <header class="masthead" style="margin:18px 0;padding:12px 0;text-align:center;">
    <p class="meta">VOL. 1 / ISSUE 47 / PRICE: ONE BAD MEMORY</p>
    <h1 style="font-size:clamp(54px,10vw,128px);margin:0;">3AM Edition</h1>
    <p>An after-hours newspaper stand for true/fake stories, public notices, corrections, and whatever your brain found after midnight.</p>
  </header>
  {newsItems.error && <p class="memo-box">Public news fallback active: {newsItems.error}</p>}

  <section class="grid-2">
    <TableBox title="Front page / room desk">
      <div class="news-columns">
        {groups.flatMap(([group, items]) => items.slice(0, 2).map((item) => (
          <article style="break-inside:avoid;border-bottom:1px dotted #8a7c5e;margin-bottom:12px;padding-bottom:10px;">
            <p class="meta">{group} / {item.byline}</p>
            <h2><a href={`/newsstand/${item.slug}`}>{item.title}</a></h2>
            <p>{item.body}</p>
          </article>
        )))}
      </div>
    </TableBox>
    <TableBox title="Corrections / legal refused">
      <div class="correction-box">
        <p><b>Correction:</b> Yesterday we reported the pool table accepted responsibility. The pool table has since retained counsel.</p>
      </div>
      <p class="classified"><strong>CLASSIFIED:</strong> Clock stuck at 1:47 seeks witness. Must be comfortable around receipts, dogs, and old vending machines.</p>
      <p class="classified"><strong>NOTICE:</strong> OmniShift denies the existence of this paper while continuing to advertise in it.</p>
    </TableBox>
  </section>

  <div class="grid-3" style="margin-top:16px;">
    {groups.map(([group, items]) => (
      <section class="newsprint-card old-shell">
        <div class="old-header">{group}</div>
        <div class="old-body">
          {items.map((item) => (
            <article style="border-top:1px solid #14110e;padding-top:10px;margin-top:10px;">
              <p class="meta">archive link / printer safe / {item.byline}</p>
              <h3><a href={`/newsstand/${item.slug}`}>{item.title}</a></h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </section>
    ))}
  </div>

  <LinkMaze title="Archive links / public notices" notice="The newsstand sells papers, rumors, corrections, and things the room remembers as fact." links={[
    { href: '/lost-found', label: 'Object archive', note: 'evidence from the drawer', stamp: 'SEE ALSO' },
    { href: '/ventures', label: 'Business notices', note: 'AI ventures nobody requested' },
    { href: '/phone', label: 'Call log tips', note: 'anonymous sources with bad service' },
    { href: '/after-hours', label: 'Back to room', note: 'where most corrections begin' }
  ]} />
</OldWebLayout>
