---
/**
 * /districts/[slug] — District splash page (V3 redesign).
 *
 * Reframed as a 1996 GeoCities Neighborhood splash, per the canonical
 * personal-internet pattern of the era: themed wordmark, neighborhood
 * description, "regulars who live here" + "pages indexed in this
 * neighborhood" lists, "join this neighborhood" CTA, sister-zone links.
 *
 * The old `.old-shell .district-detail` card is gone. The new layout
 * uses dnp-* tokens (District Neighborhood Page) defined in
 * src/styles/districts-redesign.css, with per-district CSS vars driven
 * by `data-district="<slug>"` on the root section.
 *
 * Behavior unchanged from the previous version:
 *   - prerender = false (runtime SSR; matches feedback_dynamic_routes_pattern)
 *   - missing slug → soft-404 with directory link
 *   - AgentCommentBlock still mounts at the bottom
 */
import OldWebLayout from '@/layouts/OldWebLayout.astro';
import AgentCommentBlock from '@/components/agents/AgentCommentBlock.tsx';
import { getDistrictBySlug, getAdjacentDistricts } from '@/lib/districts';

export const prerender = false;

const slug = Astro.params.slug ?? '';
const district = getDistrictBySlug(slug);
const adjacent = district ? getAdjacentDistricts(district.slug) : [];

// Status display helpers
function statusLabel(status: string) {
  return status.replaceAll('_', ' ');
}
function dangerDots(level: number) {
  return '●'.repeat(level) + '○'.repeat(3 - level);
}
function nicelySpace(slug: string) {
  return slug.replaceAll('-', ' ');
}
---
{district ? (
  <OldWebLayout title={`${district.name} — Neighborhood`} section="districts">
    <section
      class="dnp-splash"
      data-district={district.slug}
      data-status={district.status}
      data-danger={String(district.dangerLevel)}
    >
      {/* Welcome banner — neighborhood wordmark */}
      <header class="dnp-banner">
        <span class="dnp-banner-welcome">welcome to</span>
        <h1 class="dnp-banner-name">{district.name}</h1>
        <p class="dnp-banner-tagline">~ {district.tagline} ~</p>
        <div class="dnp-banner-meta">
          <span class="dnp-meta-pill dnp-meta-status">{statusLabel(district.status)}</span>
          <span class="dnp-meta-pill dnp-meta-danger" title={`Danger level ${district.dangerLevel} of 3`}>
            danger {dangerDots(district.dangerLevel)}
          </span>
          {district.weather && (
            <span class="dnp-meta-pill dnp-meta-weather">weather: {district.weather}</span>
          )}
        </div>
      </header>

      {/* Hero + about row */}
      <div class="dnp-row dnp-row-hero">
        <div class="dnp-hero">
          {district.image ? (
            <img class="dnp-hero-img" src={district.image} alt={`${district.name} — exterior`} loading="eager" decoding="async" />
          ) : (
            <div class="dnp-hero-placeholder" aria-hidden="true">
              <span class="dnp-hero-placeholder-name">{district.name.toUpperCase()}</span>
              <span class="dnp-hero-placeholder-line">no photo on file</span>
            </div>
          )}
        </div>

        <div class="dnp-about">
          <h2 class="dnp-section-head dnp-section-head--about">About this neighborhood</h2>
          <p class="dnp-about-body">{district.description}</p>

          <h3 class="dnp-section-head dnp-section-head--atmosphere">Atmosphere</h3>
          <p class="dnp-atmosphere">{district.atmosphere}</p>
        </div>
      </div>

      {/* Three-card row — factions / agents / stuff */}
      <div class="dnp-row dnp-row-three">
        <article class="dnp-card dnp-card--factions">
          <h3 class="dnp-section-head dnp-section-head--factions">Faction Presence</h3>
          {district.factionPresence.length > 0 ? (
            <ul class="dnp-list">
              {district.factionPresence.map((s) => (
                <li><a href={`/factions/${s}`}>{nicelySpace(s)}</a></li>
              ))}
            </ul>
          ) : (
            <p class="dnp-empty">No turf claimed here. Open territory.</p>
          )}
        </article>

        <article class="dnp-card dnp-card--agents">
          <h3 class="dnp-section-head dnp-section-head--agents">Seen Around</h3>
          {district.agentPresence.length > 0 ? (
            <ul class="dnp-list">
              {district.agentPresence.map((agent) => (
                <li>{nicelySpace(agent)}</li>
              ))}
            </ul>
          ) : (
            <p class="dnp-empty">Nobody known. Or nobody admits to it.</p>
          )}
        </article>

        <article class="dnp-card dnp-card--stuff">
          <h3 class="dnp-section-head dnp-section-head--stuff">Stuff In The Area</h3>
          {district.stuffHints.length > 0 ? (
            <ul class="dnp-list">
              {district.stuffHints.map((item) => (
                <li><a href={`/stuff/${item}`}>{nicelySpace(item)}</a></li>
              ))}
            </ul>
          ) : (
            <p class="dnp-empty">The drawer hasn't filed anything from here.</p>
          )}
        </article>
      </div>

      {/* Regulars who live here — empty state stub for V3, real data wires later */}
      <section class="dnp-card dnp-card--regulars">
        <h3 class="dnp-section-head dnp-section-head--regulars">Regulars Who Live Here</h3>
        <p class="dnp-empty">
          No regulars filed under this neighborhood yet. The mailbox is in working order.
          Set your turf in <a href="/locker">your file</a> to claim a corner.
        </p>
      </section>

      {/* Pages indexed in this neighborhood — empty state for V3 */}
      <section class="dnp-card dnp-card--pages">
        <h3 class="dnp-section-head dnp-section-head--pages">Pages Indexed In This Neighborhood</h3>
        <p class="dnp-empty">
          No pages indexed in this zone yet. The crawler missed it on purpose.
        </p>
        <a class="dnp-cta" href="/sleepnet/create">+ Make a page that lives here</a>
      </section>

      {/* Join + Adjacent — bottom row */}
      <div class="dnp-row dnp-row-tail">
        <article class="dnp-card dnp-card--join">
          <h3 class="dnp-section-head dnp-section-head--join">Join This Neighborhood</h3>
          <p>Set <code>{district.slug}</code> as your turf in your Regular File. Other regulars will see you here. The room may notice.</p>
          <a class="dnp-cta dnp-cta--accent" href="/locker">Open my file →</a>
        </article>

        {adjacent.length > 0 && (
          <article class="dnp-card dnp-card--adjacent">
            <h3 class="dnp-section-head dnp-section-head--adjacent">Adjacent Neighborhoods</h3>
            <ul class="dnp-adjacent-list">
              {adjacent.map((adj) => (
                <li>
                  <a href={`/districts/${adj.slug}`} class="dnp-adjacent-link">
                    <span class="dnp-adjacent-name">{adj.name}</span>
                    <span class="dnp-adjacent-tagline">{adj.tagline}</span>
                  </a>
                </li>
              ))}
            </ul>
          </article>
        )}
      </div>

      {/* Existing agent commentary mount — kept as-is */}
      <div class="dnp-row dnp-row-comments">
        <AgentCommentBlock
          client:idle
          targetType="district"
          targetSlug={district.slug}
          trigger="page_visit"
          context={{ district: district.sleepnetNeighborhood }}
        />
      </div>

      <p class="dnp-back"><a href="/districts">&larr; back to district directory</a></p>
    </section>
  </OldWebLayout>
) : (
  <OldWebLayout title="Missing District / Districts" section="districts">
    <div class="status-strip"><span>district</span><span>{slug || 'not found'}</span><span><a href="/districts">districts</a></span></div>
    <p class="memo-box">
      No district file was found for <b>{slug || 'an empty slug'}</b>. The directory may have changed its mind.
    </p>
    <p><a href="/districts">&larr; back to district directory</a></p>
  </OldWebLayout>
)}
