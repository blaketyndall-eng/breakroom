---
import OldWebLayout from '@/layouts/OldWebLayout.astro';
---
<OldWebLayout title="Staff Only" section="staff">
  <div class="old-shell" style="background:#050605;color:#33ff66;max-width:760px;margin:60px auto;">
    <div class="old-header" style="background:#000;color:#33ff66;">STAFF ONLY</div>
    <div class="old-body" style="font-family:var(--type-mono);font-size:18px;">
      <p>Access denied.</p>
      <p>You are employed, not trusted.</p>
      <p>Enter code: <input placeholder="▓▓▓▓▓▓" /></p>
    </div>
  </div>
</OldWebLayout>
