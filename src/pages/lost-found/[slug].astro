---
import ArchiveLayout from '@/layouts/ArchiveLayout.astro';
import { BREAKROOM_DATA } from '@/content/data/breakroom';
import { slugify } from '@/lib/slug';
export function getStaticPaths() {
  return BREAKROOM_DATA.objects.map((object) => ({ params: { slug: slugify(object.name) }, props: { object } }));
}
const { object } = Astro.props as any;
---
<ArchiveLayout title={`${object.name} / Object File`} eyebrow={`Object File / Item ${object.id}`}>
  <a href="/lost-found">← Return to Lost & Found</a>
  <h1>{object.name}</h1>
  <div class="grid-2">
    <div class="stripe" style="height:340px;">[{object.name} evidence image pending]</div>
    <table class="table-box">
      <tr><th>Found</th><td>{object.found}</td></tr>
      <tr><th>Condition</th><td>{object.cond}</td></tr>
      <tr><th>Meaning</th><td>{object.meaning}</td></tr>
      <tr><th>Related Uniform</th><td>{object.uniform}</td></tr>
      <tr><th>Related Clipping</th><td>{object.clip}</td></tr>
      <tr><th>Status</th><td>{object.status}</td></tr>
    </table>
  </div>
</ArchiveLayout>
