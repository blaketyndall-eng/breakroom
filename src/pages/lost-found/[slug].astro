---
/**
 * /lost-found/[slug] — DEPRECATED (308 redirect, slug-preserving).
 *
 * Per SITE-ARCHITECTURE.md, Lost & Found folds into SleepNews as a
 * Classifieds section. Per the dynamic-route doctrine in memory, this
 * uses runtime SSR (no getStaticPaths) so the slug can be read at
 * request time and forwarded into the new path.
 *
 * Inbound bookmarks for /lost-found/motel-key-no-8 land at
 * /newsstand/classifieds/motel-key-no-8 with a 308 status.
 */
export const prerender = false;

const { slug } = Astro.params;
const target = slug ? `/newsstand/classifieds/${slug}` : '/newsstand/classifieds';
return Astro.redirect(target, 308);
---
