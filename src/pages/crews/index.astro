---
import OldWebLayout from '@/layouts/OldWebLayout.astro';
import CrewCreator from '@/components/crews/CrewCreator';
import CrewDirectory from '@/components/crews/CrewDirectory';
---
<OldWebLayout title="Crews" section="crews">
  <div class="status-strip"><span>crews</span><span>not official turf</span><span>user-created</span></div>
  <section class="old-shell">
    <div class="old-header">Crews / Unofficial Organizations</div>
    <div class="old-body">
      <p class="memo-box">
        Crews are not official Turf. They are clubs, teams, locals, gangs, weird organizations, fake unions, and old-web fan clubs made by people who showed up. Management does not endorse them. Management barely acknowledges them.
      </p>

      <CrewCreator client:load />

      <CrewDirectory client:load />
    </div>
  </section>
</OldWebLayout>
