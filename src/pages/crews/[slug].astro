---
/**
 * Crew Detail Page — PR 63 (Crew Builder V2)
 *
 * Dynamic server-rendered route. The CrewDetail component
 * loads the crew from localStorage client-side, so both
 * seeded and user-created crews work.
 */
import OldWebLayout from '@/layouts/OldWebLayout.astro';
import CrewDetail from '@/components/crews/CrewDetail';
import AgentCommentBlock from '@/components/agents/AgentCommentBlock.tsx';

const { slug } = Astro.params;
---
<OldWebLayout title="Crew" section="crews">
  <div class="status-strip"><span>crew</span><span>detail</span><span>not official turf</span></div>
  <section class="old-shell crew-detail">
    <div class="old-header" id="crew-header">Crew File</div>
    <div class="old-body">
      <CrewDetail client:load crewSlug={slug!} />

      <AgentCommentBlock
        client:idle
        targetType="crew"
        targetSlug={slug!}
        trigger="page_visit"
        context={{}}
      />
    </div>
  </section>

  <p class="back-link"><a href="/crews">&larr; back to crews</a></p>
</OldWebLayout>

<script define:vars={{ slug }}>
  // Update the header with the crew name once loaded
  function updateHeader() {
    try {
      const raw = window.localStorage.getItem('breakroom.crews.v1');
      const userCrews = raw ? JSON.parse(raw) : [];
      const seededSlugs = ['late-shift-locals', 'parking-lot-council', 'object-clerks-union',
        'back-booth-regulars', 'dead-link-recovery-club', 'motel-row-watch', 'classified-readers'];

      // Check user crews first, then we'll try to find by slug in any list
      const allCrews = userCrews;
      const crew = allCrews.find(c => c.slug === slug);
      if (crew) {
        const header = document.getElementById('crew-header');
        if (header) header.textContent = crew.name;
      }
    } catch {}
  }
  if (typeof window !== 'undefined') {
    requestAnimationFrame(updateHeader);
  }
</script>
