---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PocketSignalBar from '@/components/pocket/PocketSignalBar';
import PocketFieldPrompt from '@/components/pocket/PocketFieldPrompt';
import PocketPhoneSlips from '@/components/pocket/PocketPhoneSlips';
import PocketLotConditions from '@/components/pocket/PocketLotConditions';
import PocketRadioLine from '@/components/pocket/PocketRadioLine';
import PocketQuickActions from '@/components/pocket/PocketQuickActions';
import PocketDrawerPreview from '@/components/pocket/PocketDrawerPreview';
import PocketSeenAround from '@/components/pocket/PocketSeenAround';
import PocketV1Styles from '@/components/pocket/PocketV1Styles.astro';

// Night Manager daily observations — one per day, seeded by date.
// Time-of-day pools (research: Adult Swim bump scheduling — different energy per block)
const dayOfYear = Math.floor((Date.now() - new Date(new Date().getFullYear(), 0, 0).getTime()) / 86400000);
const hour = new Date().getHours();

const lateNightObs = [
  'The parking lot has one more car than yesterday. Nobody arrived.',
  'Foot traffic increased at 1:47 AM. No one was seen.',
  'A page was created at 3AM. The author is listed as "room."',
  'The vending machine is humming a frequency that was not programmed.',
  'Security camera 4 recorded nothing. It felt strongly about it.',
  'The back door opened and closed. Wind was not present.',
  'Someone is in the lot. The lot does not confirm.',
];

const morningObs = [
  'Someone left a receipt on the counter. The items are redacted.',
  'Temperature in the back office: 1 degree cooler than it should be.',
  'The clock moved backward for one second. It corrected itself.',
  'The coffee maker started itself. Nobody asked.',
  'Morning memo on the board. Unsigned. Undated. Accurate.',
  'Daylight makes the building look like it belongs here. It does not.',
  'The overnight count is in. The numbers are technically correct.',
];

const afternoonObs = [
  'Someone moved the sign. Management denies the sign.',
  'The vending machine accepted a token that does not exist.',
  'Inventory updated. Nothing was added. Something was counted.',
  'The bulletin board has a new pin. The paper behind it is blank.',
  'A meeting was held in the back room. Attendees: 0. Minutes: filed.',
  'The phone rang once. When answered: dial tone.',
  'Shift change completed. Nobody left. Nobody arrived.',
];

const eveningObs = [
  'A door that was here yesterday is not here today. The wall is fine.',
  'A new stain on the floor. It is shaped like a decision.',
  'The lot weathered differently than the forecast. It does that.',
  'The neon turned on early. It knows something.',
  'Closing procedures were followed. The room did not close.',
  'Someone signed the guestbook after hours. The pen was not here.',
  'The jukebox selected a song. Nobody put money in.',
];

function getTimePool() {
  if (hour >= 0 && hour < 6) return lateNightObs;
  if (hour >= 6 && hour < 12) return morningObs;
  if (hour >= 12 && hour < 18) return afternoonObs;
  return eveningObs;
}

const pool = getTimePool();
const dailyObservation = pool[dayOfYear % pool.length];

// Running counter — total Pocket visits (persisted client-side, seeded here)
const baseVisitorCount = 18439 + dayOfYear;
---
<BaseLayout title="Pocket — The Breakroom" section="pocket" description="Daily access terminal. Check slips. Get lost. Leave marks.">
  <PocketV1Styles />
  <PocketSignalBar client:load />

  <!-- Bump Zone: Night Manager daily observation -->
  <div class="pocket-bump">
    {dailyObservation}
  </div>

  <!-- Field Prompt: daily micro-task (personalized) -->
  <PocketFieldPrompt client:load />

  <PocketPhoneSlips client:load />
  <PocketQuickActions client:load />
  <PocketLotConditions client:idle />
  <PocketRadioLine client:idle />
  <PocketDrawerPreview client:idle />
  <PocketSeenAround client:idle />

  <!-- Running counter (client-incremented) -->
  <div class="pocket-counter" id="pocket-counter">
    pocket access #{baseVisitorCount} · clock stuck at 1:47
  </div>
  <script define:vars={{ baseVisitorCount }}>
    try {
      // Counter persistence
      const key = 'breakroom.pocket-visits.v1';
      const stored = parseInt(localStorage.getItem(key) || '0', 10);
      const visits = stored + 1;
      localStorage.setItem(key, String(visits));
      const total = baseVisitorCount + visits;
      const el = document.getElementById('pocket-counter');
      if (el) el.textContent = `pocket access #${total} · clock stuck at 1:47`;

      // Dynamic page title with slip count
      const slipsRaw = localStorage.getItem('breakroom.pocket-slips.v1');
      if (slipsRaw) {
        const slips = JSON.parse(slipsRaw);
        const unread = slips.filter(s => !s.read).length;
        if (unread > 0) {
          document.title = `(${unread}) Pocket — The Breakroom`;
        }
      }
      // Register service worker for offline pocket shell
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/pocket-sw.js', { scope: '/pocket' })
          .catch(() => {}); // Silent fail — offline is a bonus, not a requirement
      }
    } catch {}
  </script>

  <!-- Pull-to-refresh indicator (hidden by default) -->
  <div class="pocket-pull-indicator" id="pocket-pull-indicator">
    <span class="pocket-pull-text">checking the wire...</span>
  </div>

  <script>
    // Pull-to-refresh gesture handler
    // Research: native app pull-to-refresh, but for old-web terminal feel
    (function() {
      let startY = 0;
      let pulling = false;
      const threshold = 60;
      const indicator = document.getElementById('pocket-pull-indicator');
      if (!indicator) return;

      document.addEventListener('touchstart', (e) => {
        if (window.scrollY === 0) {
          startY = e.touches[0].clientY;
          pulling = true;
        }
      }, { passive: true });

      document.addEventListener('touchmove', (e) => {
        if (!pulling) return;
        const dy = e.touches[0].clientY - startY;
        if (dy > 0 && dy < 120) {
          const progress = Math.min(dy / threshold, 1);
          indicator.style.height = Math.max(dy * 0.4, 0) + 'px';
          indicator.style.opacity = String(progress);
          if (progress >= 1) {
            indicator.querySelector('.pocket-pull-text').textContent = 'release to refresh';
          } else {
            indicator.querySelector('.pocket-pull-text').textContent = 'checking the wire...';
          }
        }
      }, { passive: true });

      document.addEventListener('touchend', () => {
        if (!pulling) return;
        const h = parseFloat(indicator.style.height) || 0;
        pulling = false;

        if (h >= threshold * 0.4) {
          // Threshold met — reload
          indicator.querySelector('.pocket-pull-text').textContent = 'the room is updating.';
          indicator.style.height = '32px';
          indicator.style.opacity = '1';
          if ('vibrate' in navigator) {
            try { navigator.vibrate(10); } catch {}
          }
          setTimeout(() => { window.location.reload(); }, 400);
        } else {
          // Snap back
          indicator.style.height = '0px';
          indicator.style.opacity = '0';
        }
      }, { passive: true });
    })();
  </script>

  <!-- Footer -->
  <div class="pocket-footer">
    <a href="/clock-out">clock out</a>
    <span class="pocket-footer-sep">&middot;</span>
    <a href="/after-hours">full site</a>
    <span class="pocket-footer-sep">&middot;</span>
    <a href="/sleeper-net">sleepnet</a>
  </div>
</BaseLayout>
