---
import OldWebLayout from '@/layouts/OldWebLayout.astro';
import { getPublicVentures } from '@/lib/publicContent';

const ventures = await getPublicVentures();
---
<OldWebLayout title="OmniShift Ventures" section="ventures">
  <div class="status-strip"><span>AI venture desk</span><span>capital allocation: suspicious</span><span>executive confidence: high</span><span>source: {ventures.source}</span></div>
  <h1>OmniShift Ventures</h1>
  <p>The AI is constantly investing, acquiring, inventing, and assigning businesses. Executives do not understand it, but the charts look confident.</p>
  {ventures.error && <p class="memo-box">Public ventures fallback active: {ventures.error}</p>}
  <table class="table-box">
    <tbody>
      <tr><th>Name</th><th>Category</th><th>Status</th><th>AI Rationale</th><th>Memo</th></tr>
      {ventures.items.map((venture) => (
        <tr>
          <td>{venture.name}</td>
          <td>{venture.category}</td>
          <td>{venture.status}</td>
          <td>{venture.description}</td>
          <td>{venture.memo}</td>
        </tr>
      ))}
    </tbody>
  </table>
</OldWebLayout>
