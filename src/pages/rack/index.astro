---
import OldWebLayout from '@/layouts/OldWebLayout.astro';
import TableBox from '@/components/oldweb/TableBox.astro';
import CatalogRail from '@/components/oldweb/CatalogRail.astro';
import { getPublicProducts } from '@/lib/publicContent';

const products = await getPublicProducts();
const catalogItems = products.items.map((product) => ({
  sku: product.sku,
  name: product.name,
  note: product.note,
  href: product.href,
  status: product.status,
}));
---
<OldWebLayout title="The Rack" section="rack">
  <div class="status-strip"><span>2003 inventory page</span><span>issue: Shift End</span><span>checkout disabled</span><span>products appear as files</span><span>source: {products.source}</span></div>

  <section class="hero-split">
    <div>
      <p class="eyebrow">Uniform archive / live-ish inventory</p>
      <h1>The Rack</h1>
      <p class="lede">Products are issued goods, product sightings, file requests, and things removed from the rack before anyone admits they were for sale.</p>
      {products.error && <p class="memo-box">Public product fallback active: {products.error}</p>}
    </div>
    <aside class="evidence-card">
      <p><b>Inventory warning:</b> Staff count and item count do not match.</p>
      <p><b>Checkout:</b> not enabled yet.</p>
      <p><b>Approved move:</b> request a file, save the object, wait under bad lights.</p>
      <p><span class="red-stamp">NO CART / FILE ONLY</span></p>
    </aside>
  </section>

  <CatalogRail title="Featured issue files / 2003 catalog rail" items={catalogItems.slice(0, 5)} />

  <div class="rack-tools old-shell">
    <div class="old-header">Filter inventory</div>
    <div class="old-body rack-filter-row">
      <span>Status: available / removed / disputed</span>
      <span>Issue: Shift End</span>
      <span>Department: all</span>
      <span>Sort: last seen</span>
      <span>Payment: not accepted</span>
    </div>
  </div>

  <table class="table-box rack-table">
    <thead><tr><th>SKU</th><th>Item File</th><th>Status</th><th>Dept.</th><th>Object</th><th>Action</th></tr></thead>
    <tbody>
      {products.items.map((product) => (
        <tr class="inventory-row" data-status={product.status}>
          <td>{product.sku}</td>
          <td><a href={product.href}>{product.name}</a><br/><span>{product.note}</span></td>
          <td><span class="status-tag">{product.status}</span></td>
          <td>{product.department}</td>
          <td>{product.object}</td>
          <td><a class="old-button" href={product.href}>Open File</a></td>
        </tr>
      ))}
      <tr class="inventory-row" data-status="CLOCK">
        <td>SE-██</td><td>████ ███████ ███<br/><span>Product visible only after the room says yes.</span></td><td>CLOCK OUT TO VIEW</td><td>Wrong Department</td><td>Redacted</td><td><a href="/clock-out">Clock Out</a></td>
      </tr>
    </tbody>
  </table>

  <section class="grid-2" style="margin-top:20px;">
    <TableBox title="Build your shift">
      <p>Not a cart. Not yet. Choose a uniform direction and the room will remember the preference later.</p>
      <form class="old-form">
        <label>Preferred light <select><option>dirty fluorescent</option><option>motel blue</option><option>dashboard green</option><option>beer sign red</option></select></label>
        <label>Preferred item <select>{products.items.map((product) => <option>{product.name}</option>)}</select></label>
        <button class="old-button" type="button">Save Preference / Later</button>
      </form>
    </TableBox>
    <TableBox title="Removed from rack / staff notes">
      <ul>
        <li>White swan staff jacket — wrong department.</li>
        <li>Room 8 work shirt — key required.</li>
        <li>Applause Money cap — finance objected.</li>
        <li>Felt-green work pants — photographed once, denied twice.</li>
      </ul>
    </TableBox>
  </section>
</OldWebLayout>
