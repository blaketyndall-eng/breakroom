---
import OldWebLayout from '@/layouts/OldWebLayout.astro';
import RadioPlayer from '@/components/radio/RadioPlayer';
import RadioNowPlaying from '@/components/radio/RadioNowPlaying';
import RadioLogWidget from '@/components/radio/RadioLogWidget';
import RadioRequestForm from '@/components/radio/RadioRequestForm';
import SecretTrigger from '@/components/breakroom/SecretTrigger';
import { getPublicRadioLogs } from '@/lib/publicContent';
import {
  STATION_IDENTITY,
  WORDMARK,
  RADIO_SCHEDULE,
  SCHEDULE_NOTE,
  SHOW_TYPE_LABEL,
  BUMPERS,
  CARL_TRANSMISSION,
  pickFccLetter,
  pickSponsorSlot,
  pickPhoneCount,
} from '@/content/data/radioBrand';

const radioLogs = await getPublicRadioLogs();

// Server-side picks. Deterministic seeds keep SSR matched to first paint.
const now = Date.now();
const sponsor = pickSponsorSlot(now);
const fcc = pickFccLetter(now);
const phoneLine = pickPhoneCount(now);

// T4-A: Carl's NIGHT counter is days since 2026-02-08 (three months back).
// Stable canon: he started calling "three months, every night." The number
// drifts with real time; doesn't reset.
const CARL_CUTOFF = Date.UTC(2026, 1, 8); // Feb 8 2026 00:00 UTC (month is 0-indexed)
const carlNight = Math.max(1, Math.floor((now - CARL_CUTOFF) / (24 * 60 * 60 * 1000)));

// T4-H: Compute which schedule slot is "now" based on local server time.
// Slot start times in minutes since midnight: 1:47, 2:13, 3:00, 4:11, 4:47, 5:30, 6:00.
// Any time >= 6:00 falls into the sign-off slot (last index) since the station
// broadcasts static through the day. Times before 1:47am map to null.
const slotMins = [107, 133, 180, 251, 287, 330, 360];
function currentSlotIdx(t: number): number | null {
  if (t < slotMins[0]) return null;
  for (let i = slotMins.length - 1; i >= 0; i--) {
    if (t >= slotMins[i]) return i;
  }
  return null;
}
const dt = new Date(now);
const totalMin = dt.getHours() * 60 + dt.getMinutes();
const currentSlot = currentSlotIdx(totalMin);

const switchboardLinks = [
  { href: '/phone',      label: 'Phone logs',      note: 'where most transmissions begin', stamp: 'SOURCE'  },
  { href: '/newsstand',  label: 'Station notices', note: 'misreported after airing',       stamp: '3AM'     },
  { href: '/idle-hands', label: 'Bracket break',   note: 'pool reports, table disputes',   stamp: 'SPORTS'  },
  { href: '/factions',   label: 'Faction beef',    note: 'disputes the station won’t resolve' },
  { href: '/lost-found', label: 'Cue room objects',note: 'chalk, timing slips, keys, receipts' },
  { href: '/after-hours',label: 'Back to room',    note: 'the booth is probably behind the bar' },
];
---
<OldWebLayout title="Breakroom Radio / Channel 1:47" section="radio">
  {/* T4-G: SecretTrigger wrapped to keep its initial "checking" text out of the a11y tree. */}
  <span aria-hidden="true"><SecretTrigger client:load trigger="visit:/radio" path="/radio" label="radio 1:47" /></span>

  <section class="r147-page">
    <header class="r147-banner">
      <h1 class="r147-banner-title">{WORDMARK.primary}</h1>
      <p class="r147-banner-sub">{WORDMARK.subline}</p>
      <p class="r147-banner-meta"><span>{STATION_IDENTITY.callsign}</span> · <span>{STATION_IDENTITY.frequency}</span></p>
      <p class="r147-banner-tagline">{WORDMARK.tagline}</p>
      <div class="r147-tower" aria-hidden="true">
        ▲<span class="r147-tower-light"></span>
        ▴
        ▲<span class="r147-tower-light" style="animation-delay: -1.2s;"></span>
        ▴
        ▲<span class="r147-tower-light" style="animation-delay: -0.6s;"></span>
      </div>
    </header>

    <div class="r147-status-strip">
      <span><span class="r147-status-dot" aria-hidden="true"></span><b class="r147-status-onair">ON AIR</b></span>
      <span>signal: cigarette-yellow</span>
      <span>weather: dim</span>
      <span>next: lot weather (1:47)</span>
      <span>{phoneLine}</span>
    </div>

    {radioLogs.error && (
      <p class="r147-sponsor">Public radio fallback active: {radioLogs.error}</p>
    )}

    <div class="r147-grid-top">
      <RadioPlayer client:load />
      <div class="r147-np-card">
        <RadioNowPlaying client:load />
      </div>
    </div>

    <p class="r147-sponsor">{sponsor}</p>

    {/* T4-H: data-current marks the live row.
        T4-F: <th scope="col"> on each header so screen readers announce them. */}
    <section class="r147-schedule">
      <h2 class="r147-schedule-head">The Schedule</h2>
      <table class="r147-schedule-table">
        <thead>
          <tr>
            <th scope="col">Time</th>
            <th scope="col">Show</th>
            <th scope="col">Host</th>
            <th scope="col">Type</th>
          </tr>
        </thead>
        <tbody>
          {RADIO_SCHEDULE.map((slot, idx) => (
            <tr {...(idx === currentSlot ? { 'data-current': 'true' } : {})}>
              <td class="r147-schedule-time">{slot.time}</td>
              <td>
                <div class="r147-schedule-show">{slot.show}</div>
                {slot.note && <span class="r147-schedule-row-note">{slot.note}</span>}
              </td>
              <td class="r147-schedule-host">{slot.host}</td>
              <td>
                <span class={`r147-schedule-chip r147-chip-${slot.type}`}>
                  {SHOW_TYPE_LABEL[slot.type]}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      <p class="r147-schedule-note">{SCHEDULE_NOTE}</p>
    </section>

    <div class="r147-grid-bottom">
      <div class="r147-log">
        <RadioLogWidget client:idle limit={15} />
      </div>

      <aside class="r147-side">
        <div class="r147-request">
          <RadioRequestForm client:idle />
        </div>

        {/* T4-A: data-night drives the dynamic NIGHT counter via CSS attr(). */}
        <div class="r147-carl" data-night={carlNight}>
          <p class="r147-carl-label">Caller: {CARL_TRANSMISSION.caller} · {CARL_TRANSMISSION.duration}</p>
          <p class="r147-carl-msg">{CARL_TRANSMISSION.message}</p>
          <span class="r147-carl-file">{CARL_TRANSMISSION.fileLabel}</span>
        </div>

        <article class="r147-fcc">
          <span class="r147-fcc-stamp">Read on Air</span>
          <p class="r147-fcc-from">{fcc.fromOffice}</p>
          <p class="r147-fcc-meta">Date: <b>{fcc.date}</b></p>
          <p class="r147-fcc-meta">To: <b>{fcc.addressedTo}</b></p>
          <p class="r147-fcc-subject">Re: {fcc.subject}</p>
          <p class="r147-fcc-body">{fcc.body}</p>
          <p class="r147-fcc-sig">{fcc.signature}</p>
        </article>
      </aside>
    </div>

    <div class="r147-bumper" aria-hidden="true">
      <div class="r147-bumper-track">
        {[...BUMPERS, ...BUMPERS].map((line) => <span>{line}</span>)}
      </div>
    </div>

    <nav class="r147-switchboard">
      <h3 class="r147-switchboard-head">Radio Switchboard</h3>
      <p class="r147-switchboard-note">The station does not take requests. It takes evidence and calls it programming.</p>
      <ul class="r147-switchboard-list">
        {switchboardLinks.map((link) => (
          <li class="r147-switchboard-item">
            {link.stamp && <span class="r147-switchboard-stamp">{link.stamp}</span>}
            <a class="r147-switchboard-link" href={link.href}>{link.label}</a>
            <span class="r147-switchboard-note-line">— {link.note}</span>
          </li>
        ))}
      </ul>
    </nav>

    {/* T4-E: Inner footer demoted to <div> so the global bm-foot keeps the
        sole contentinfo landmark on the page. */}
    <div class="r147-foot">
      <span><span class="r147-foot-callsign">{STATION_IDENTITY.callsign}</span> · {STATION_IDENTITY.frequency}</span>
      <span>{STATION_IDENTITY.broadcastOrigin}</span>
      <a href="/void">&larr; back to VOID portal</a>
    </div>
  </section>
</OldWebLayout>
