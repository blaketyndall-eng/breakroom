---
import OldWebLayout from '@/layouts/OldWebLayout.astro';
import FactionPage from '@/components/factions/FactionPage.astro';
import FactionDriftPageMarker from '@/components/factions/FactionDriftPageMarker.astro';
import { getFactionBySlug } from '@/content/data/factions';

export const prerender = false;

const slug = Astro.params.slug ?? '';
const faction = getFactionBySlug(slug);
---
<OldWebLayout title={`${faction?.name ?? 'Missing Turf'} / Factions`} section="factions">
  <div class="status-strip"><span>faction file</span><span>{faction ? faction.slug : 'not found'}</span><span>{faction ? faction.status : 'missing'}</span><span><a href="/factions">factions</a></span></div>
  {faction ? (
    <>
      <FactionDriftPageMarker factionSlug={faction.slug} factionName={faction.name} source="visit_faction_page" />
      <FactionPage faction={faction} />
    </>
  ) : (
    <p class="memo-box">No faction file was found for {slug}. The room may have moved turf while you were standing there.</p>
  )}
</OldWebLayout>
