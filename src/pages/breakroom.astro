---
import OldWebLayout from '@/layouts/OldWebLayout.astro';
import TableBox from '@/components/oldweb/TableBox.astro';
import LinkMaze from '@/components/oldweb/LinkMaze.astro';
import ObjectEvidenceGrid from '@/components/oldweb/ObjectEvidenceGrid.astro';
import AuthPanel from '@/components/auth/AuthPanel';
---
<OldWebLayout title="A bunch of bull sh*t, right?" section="breakroom">
  <section class="hero-grid">
    <div>
      <p class="breakroom-mark">BRKRM / employee resources / corrupted</p>
      <h1>A bunch of bull sh*t, right?</h1>
      <p class="lede">This is the conversation with the coworker who knows the same thing you know. The page still functions. It just stopped respecting the company.</p>
      <div class="status-strip"><span>OmniShift Internal</span><span>rogue edits detected</span><span>clock 1:47</span><span>breakroom access pending</span></div>
      <div class="corporate-overwrite">
        <p><b>Management language removed.</b> This page was supposed to explain culture, benefits, and operational alignment. Somebody changed it after the coffee got cold.</p>
        <p><a class="old-button" href="/signup">Sign up for whatever this is</a> <a class="old-button" href="/portal">Employee file</a></p>
      </div>
    </div>
    <AuthPanel client:load compact redirectTo="/portal" />
  </section>

  <LinkMaze title="Employee portal links / some approved, some not" notice="Clicking around is part of intake. HR says this is not legally binding, then asks for your badge number." links={[
    { href: '/portal', label: 'Employee file', note: 'assigned identity, generated by accident', stamp: 'APPROVED' },
    { href: '/clock-out', label: 'Clock Out', note: 'the only useful company button', stamp: '1:47' },
    { href: '/after-hours', label: 'After Hours', note: 'hidden room under the mainframe', stamp: 'UNLISTED' },
    { href: '/idle-hands', label: 'Idle Hands', note: 'pool tournament, maybe recurring', stamp: 'CASH' },
    { href: '/lost-found', label: 'Lost & Found', note: 'objects with better memory than people' },
    { href: '/newsstand', label: 'Newsstand', note: '3AM edition, printer-friendly lies' },
    { href: '/phone', label: 'Phone log', note: 'rides, food, wrong numbers, dispatch' },
    { href: '/radio', label: 'Radio 1:47', note: 'channel still looking for a tower' }
  ]} />

  <ObjectEvidenceGrid title="Objects left on the counter during the conversation" items={[
    { name: 'Cracked company phone', detail: 'One voicemail from dispatch. Battery dead. Screen still glowing.', href: '/phone', code: 'CALL-147' },
    { name: 'Badge with no photo', detail: 'Name field printed twice. Department says BACK HALL.', href: '/portal', code: 'ID-VOID' },
    { name: 'Receipt with no total', detail: 'Coffee, chalk, motel lamp, apology. No amount due.', href: '/lost-found', code: 'RCPT-000' },
    { name: 'Clock-out slip', detail: 'Signed by someone who left before they were hired.', href: '/clock-out', code: 'SHIFT-END' }
  ]} />

  <div class="grid-3">
    <TableBox title="Employee Resources">
      <p><a href="/portal">View assigned employee file</a></p>
      <p><a href="/clock-out">Clock Out</a></p>
      <p><a href="/house-rules">House Rules</a></p>
    </TableBox>
    <TableBox title="Unauthorized Room Links">
      <p><a href="/after-hours">After Hours</a></p>
      <p><a href="/lost-found">Lost & Found</a></p>
      <p><a href="/newsstand">3AM Edition</a></p>
    </TableBox>
    <TableBox title="Management Notice">
      <p>AI leadership confirms the room is aligned with business outcomes. No one knows what that means.</p>
      <p class="red-stamp">Do not thank the room.</p>
    </TableBox>
  </div>
</OldWebLayout>
