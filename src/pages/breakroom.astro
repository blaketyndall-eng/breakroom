---
import OldWebLayout from '@/layouts/OldWebLayout.astro';
import TableBox from '@/components/oldweb/TableBox.astro';
import RedStamp from '@/components/oldweb/RedStamp.astro';
---
<OldWebLayout title="Employee Resources / Breakroom" section="breakroom">
  <div class="status-strip"><span>OMNISHIFT EMPLOYEE RESOURCES</span><span>Page modified by unknown employee</span><span>1:47 AM</span></div>

  <section class="hero-split">
    <div>
      <p class="eyebrow">Internal page / poorly supervised</p>
      <h1>A bunch of bullsh*t, right?</h1>
      <p class="lede">This was supposed to be an employee resource page. Somebody got into the mainframe and made it honest.</p>
      <p>Corporate still functions here. The room has simply written in the margins.</p>
    </div>
    <aside class="evidence-card">
      <RedStamp text="ALTERED" />
      <p><b>Current status:</b> useful and broken.</p>
      <p><b>Clock:</b> wrong according to management, correct according to everyone still here.</p>
      <p><b>Next approved action:</b> open your file, then clock out.</p>
    </aside>
  </section>

  <div class="grid-2">
    <TableBox title="Approved Language / Actual Meaning">
      <table class="table-box">
        <thead><tr><th>Approved</th><th>Actual</th></tr></thead>
        <tbody>
          <tr><td>Culture alignment</td><td>Everybody is tired in the same direction.</td></tr>
          <tr><td>Operational excellence</td><td>The coffee is active again.</td></tr>
          <tr><td>Workforce optimization</td><td>You have been hired by mistake.</td></tr>
          <tr><td>Employee engagement</td><td>Someone found a door behind the vending machine.</td></tr>
          <tr><td>AI transformation</td><td>The executives are pretending not to be scared.</td></tr>
        </tbody>
      </table>
    </TableBox>

    <TableBox title="Entry Points">
      <p><a class="old-button" href="/portal">Open OmniShift Employee File</a></p>
      <p><a class="old-button" href="/clock-out">Clock Out</a></p>
      <p><a class="old-button" href="/after-hours">After Hours</a></p>
      <p class="small-note">If After Hours opens too easily, pretend it did not.</p>
    </TableBox>
  </div>

  <TableBox title="Recovered Assets">
    <div class="recovered-grid">
      <a href="/lost-found"><b>Lost & Found</b><span>Object archive, evidence files, items not returned.</span></a>
      <a href="/rack"><b>The Rack</b><span>Issued goods, redacted products, uniforms with a bad explanation.</span></a>
      <a href="/newsstand"><b>3AM Edition</b><span>Headlines, corrections, classified ads, things taken out of context.</span></a>
      <a href="/idle-hands"><b>Idle Hands Invitational</b><span>Old pool tournament page. Reality unresolved.</span></a>
      <a href="/radio"><b>Channel 1:47</b><span>Radio from somewhere behind the bar.</span></a>
      <a href="/staff-only"><b>Staff Only</b><span>You are employed, not trusted.</span></a>
    </div>
  </TableBox>
</OldWebLayout>
