---
/**
 * /breakroom — the OmniShift bridge page where things start to break down.
 *
 * Mirrors /portal's os-corp-header / os-tabs / os-portal-layout chrome
 * (CLEAN-3, 2026-05-07) but corrupts every layer with intentional cracks:
 * disabled tabs, REDACTED policy memos, [404] sidebar links, broken-feeling
 * system status. Functions as the doorway from OmniShift to Void Signal.
 *
 * Still on the corporate side per worldMap.ts (section="breakroom" →
 * omnishift). The visual register communicates that this page has
 * stopped respecting management.
 */
import OldWebLayout from '@/layouts/OldWebLayout.astro';
import AuthPanel from '@/components/auth/AuthPanel';
---
<OldWebLayout title="A bunch of bull sh*t, right?" section="breakroom" level={4}>

  <!-- Corporate header — still on-brand but the meta is broken -->
  <div class="os-corp-header">
    <div class="os-corp-brand">
      <span class="os-logo">OMNI<span class="os-logo-accent">SHIFT</span></span>
      <span class="os-logo-tagline">Employee Services / Breakroom / <span class="brkrm-corrupt">UNAUTHORIZED EDIT</span></span>
    </div>
    <div class="os-corp-meta">
      <span class="brkrm-corrupt">Session: undefined</span>
      <span>Last login: <s>1:47 AM</s> never</span>
      <span class="os-blink brkrm-flicker">● UNTRUSTED</span>
    </div>
  </div>

  <!-- Tab navigation — half work, half are [DENIED] -->
  <nav class="os-tabs">
    <a href="/portal">Home</a>
    <a href="/breakroom" class="active">Breakroom</a>
    <span class="os-tab-disabled">Ventures <small>[DENIED]</small></span>
    <a href="/lost-found">Object Archive</a>
    <span class="os-tab-disabled">Company News <small>[DENIED]</small></span>
    <a href="/clock-out">Clock Out</a>
  </nav>

  <!-- Masthead — same exterior photo, but stamped REDACTED with tampered caption -->
  <div class="os-portal-masthead brkrm-masthead">
    <img
      src="/void/districtParkingLotWest.jpg"
      alt="The Breakroom — exterior at 1:47 a.m. (employee-submitted)"
      loading="eager"
      decoding="async"
    />
    <div class="brkrm-masthead-stamp">REDACTED — INTERNAL</div>
    <div class="os-portal-masthead-caption">
      <span>EMPLOYEE BREAK AREA — WEST LOT — 1:47 A.M.</span>
      <span>Photo not approved by Compliance & Felt</span>
    </div>
  </div>

  <!-- Alert bar — corporate notice struck through, overwritten in yellow -->
  <div class="os-alert-bar brkrm-alert">
    <span class="os-alert-icon">⚠</span>
    <s>SYSTEM NOTICE: All breakroom conversations are recorded for compliance.</s>
    <span class="brkrm-overwrite">NOTHING IS RECORDED. THE COFFEE GOT COLD. TALK FAST.</span>
  </div>

  <!-- 3-column portal layout, mirroring /portal but corrupted -->
  <div class="os-portal-layout">

    <!-- Left sidebar: Quick Links + System Status + Department Directory -->
    <aside class="os-sidebar-left">

      <div class="os-widget">
        <div class="os-widget-header">Quick Links</div>
        <div class="os-widget-body">
          <a href="/portal">Employee File</a>
          <a href="/clock-out">Clock Out</a>
          <a href="/after-hours">After Hours <small style="color:#888;">(unsupervised)</small></a>
          <span class="brkrm-link-broken">HR Resources <small>[404]</small></span>
          <span class="brkrm-link-broken">Salary Bands <small>[404]</small></span>
          <a href="/idle-hands">Idle Hands</a>
        </div>
      </div>

      <div class="os-widget">
        <div class="os-widget-header">System Status</div>
        <div class="os-widget-body os-status-list">
          <div class="os-status-row">
            <span class="os-status-dot os-dot-red"></span>
            <span>Portal Services</span>
          </div>
          <div class="os-status-row">
            <span class="os-status-dot os-dot-red"></span>
            <span>Employee Database</span>
          </div>
          <div class="os-status-row">
            <span class="os-status-dot os-dot-grey"></span>
            <span>Management Authority</span>
          </div>
          <div class="os-status-row">
            <span class="os-status-dot os-dot-yellow"></span>
            <span>The Coffee</span>
          </div>
          <div class="os-status-row">
            <span class="os-status-dot os-dot-green brkrm-pulse"></span>
            <span>The Room</span>
          </div>
        </div>
      </div>

      <div class="os-widget">
        <div class="os-widget-header">Department Directory</div>
        <div class="os-widget-body os-dept-list">
          <span class="brkrm-dept-deleted">Fluorescent Operations</span>
          <span class="brkrm-dept-deleted">Lot Hours</span>
          <a href="#">Night Audit (Office Closed)</a>
          <span class="brkrm-dept-deleted">Compliance & Felt</span>
          <a href="#">Vacancy Logistics (out)</a>
          <a href="#">Chalk & Aim (busy)</a>
        </div>
      </div>

    </aside>

    <!-- Main content -->
    <main class="os-main">

      <!-- Hero portlet — preserves Blake's original copy, reframed in os-* chrome -->
      <div class="os-portlet">
        <div class="os-portlet-header">
          <span class="os-portlet-icon">📋</span>
          A bunch of bull sh*t, right?
        </div>
        <div class="os-portlet-body">
          <p class="brkrm-mark">BRKRM / employee resources / corrupted</p>
          <p class="brkrm-lede">This is the conversation with the coworker who knows the same thing you know. The page still functions. It just stopped respecting the company.</p>
          <p style="margin-top:14px;">
            <a class="brkrm-btn-primary" href="/signup">Sign up for whatever this is</a>
            <a class="brkrm-btn-secondary" href="/portal">View Employee File</a>
            <a class="brkrm-btn-secondary" href="/clock-out">Clock Out</a>
          </p>
        </div>
      </div>

      <!-- Sign-in widget — useful but suspiciously casual for a corporate page -->
      <div class="os-portlet">
        <div class="os-portlet-header">
          <span class="os-portlet-icon">🔑</span>
          Sign In <small style="color:#aaa;font-size:11px;">— if you must</small>
        </div>
        <div class="os-portlet-body">
          <AuthPanel client:load compact redirectTo="/portal" />
        </div>
      </div>

      <!-- Policy notices — corrupted, REDACTED, overwritten -->
      <div class="os-portlet">
        <div class="os-portlet-header">
          <span class="os-portlet-icon">📜</span>
          Policy Notices <small style="color:#aaa;font-size:11px;">— some accurate, most amended</small>
        </div>
        <div class="os-portlet-body">

          <div class="os-policy">
            <p class="os-policy-id">POLICY OS-2024-147 <span class="brkrm-stamp">EDITED 1:47 A.M.</span></p>
            <p><strong>Re: <s>After-Hours Conduct</s> The Conversation You Are Having</strong></p>
            <p><s>All employees are reminded that clocking out does not constitute leaving. OmniShift retains observation rights over all rooms, lots, and adjacent parking structures.</s> <span class="brkrm-overwrite">The room is on your side. The company will not enjoy this.</span></p>
          </div>

          <div class="os-policy brkrm-redacted-block">
            <p class="os-policy-id">POLICY OS-2024-003 <span class="brkrm-stamp">REDACTED</span></p>
            <p><strong>Re: ████████████████████</strong></p>
            <p>███████ ████ ███████ ███ ████████ █ ██████. ████ ███ ████████ ████ ████████. The policy has always existed. The policy is also missing.</p>
          </div>

          <div class="os-policy">
            <p class="os-policy-id">MEMO — UNFILED</p>
            <p><strong>Re: Whoever changed this page</strong></p>
            <p>Whoever you are: the room thanks you. <span class="brkrm-handwritten">don't thank the room. — anonymous</span></p>
          </div>

        </div>
      </div>

    </main>

    <!-- Right sidebar: Off-Book Notices + Items Left On The Counter + Help -->
    <aside class="os-sidebar-right">

      <div class="os-widget">
        <div class="os-widget-header">Off-Book Notices</div>
        <div class="os-widget-body">
          <div class="os-announce">
            <p class="os-announce-date">1:47</p>
            <p class="os-announce-title">Coffee Got Cold</p>
            <p>Whoever made it forgot. The coffee was a gesture. The gesture has been received.</p>
          </div>
          <div class="os-announce">
            <p class="os-announce-date">TBD</p>
            <p class="os-announce-title">Rogue Edit Detected</p>
            <p>This page was edited. Management has not approved. Management is also not coming.</p>
          </div>
          <div class="os-announce">
            <p class="os-announce-date">—</p>
            <p class="os-announce-title">Phone Was Off The Hook</p>
            <p>Now it is on the hook. We are not telling you who answered.</p>
          </div>
        </div>
      </div>

      <div class="os-widget">
        <div class="os-widget-header">Items Left On The Counter</div>
        <div class="os-widget-body os-events">
          <div class="os-event">
            <span class="os-event-date">CALL-147</span>
            <span><a href="/phone">Cracked company phone</a></span>
          </div>
          <div class="os-event">
            <span class="os-event-date">ID-VOID</span>
            <span><a href="/portal">Badge with no photo</a></span>
          </div>
          <div class="os-event">
            <span class="os-event-date">RCPT-000</span>
            <span><a href="/lost-found">Receipt with no total</a></span>
          </div>
          <div class="os-event">
            <span class="os-event-date">END</span>
            <span><a href="/clock-out">Clock-out slip</a></span>
          </div>
        </div>
      </div>

      <div class="os-widget">
        <div class="os-widget-header">Help & Support</div>
        <div class="os-widget-body">
          <p style="font-size:12px;color:#5a6b58;margin:0 0 6px;">IT does not exist on this page. The phone behind the bar may answer.</p>
          <a href="/phone" style="font-size:12px;">Phone Behind The Bar →</a>
        </div>
      </div>

    </aside>

  </div>

  <!-- Footer — uptime is suspect -->
  <div class="os-portal-footer brkrm-footer">
    <p>OmniShift Corporation — Breakroom (employee-edited)</p>
    <p>© OmniShift Holdings LLC / This page has been amended without authorization. Compliance has been notified. Compliance is not coming. Both statements are correct.</p>
    <p style="font-size:10px;color:#8a9b88;">Server: OSPORTAL-PROD-03 | Session: <s>0x1A47F</s> 0x???? | Uptime: 1,847 days | Last Edit: 1:47 A.M. by ████████</p>
  </div>

  <!-- Page-specific corruption styles. Localized to /breakroom only. -->
  <style>
    .brkrm-corrupt {
      color: #c80000;
      text-shadow: 1px 0 0 #ff8a00;
      font-weight: 700;
    }
    .brkrm-flicker { animation: brkrm-flicker 1.4s steps(2, start) infinite; }
    @keyframes brkrm-flicker {
      0%, 100% { opacity: 1; }
      50%      { opacity: 0.4; }
    }
    .brkrm-pulse { animation: brkrm-pulse 1.6s ease-in-out infinite; }
    @keyframes brkrm-pulse {
      0%, 100% { opacity: 1;   transform: scale(1); }
      50%      { opacity: 0.6; transform: scale(1.15); }
    }
    /* Disabled tab — gray with line-through, not clickable */
    .os-tab-disabled {
      color: #999;
      cursor: not-allowed;
      text-decoration: line-through;
      padding: 4px 14px;
      font-size: 12px;
      display: inline-block;
    }
    .os-tab-disabled small {
      font-size: 9px;
      letter-spacing: 0.08em;
      color: #c80000;
      margin-left: 4px;
      text-decoration: none;
    }
    /* Masthead with rotated REDACTED stamp overlay */
    .brkrm-masthead { position: relative; }
    .brkrm-masthead-stamp {
      position: absolute;
      top: 12px;
      right: 16px;
      background: #c80000;
      color: #fff;
      font-family: 'Special Elite', monospace;
      font-size: 11px;
      padding: 4px 12px;
      letter-spacing: 0.08em;
      transform: rotate(-3deg);
      box-shadow: 1px 1px 0 #6a0000;
      z-index: 2;
    }
    /* Alert bar overwrite patch */
    .brkrm-alert s { opacity: 0.6; }
    .brkrm-overwrite {
      background: #ffe000;
      color: #1a0a2e;
      padding: 1px 6px;
      font-family: 'Special Elite', monospace;
      font-weight: 700;
      margin-left: 6px;
    }
    /* Broken sidebar links */
    .brkrm-link-broken {
      display: block;
      color: #999;
      cursor: not-allowed;
      text-decoration: line-through;
      padding: 2px 0;
      font-size: 12px;
    }
    .brkrm-link-broken small {
      font-size: 9px;
      color: #c80000;
      margin-left: 4px;
      letter-spacing: 0.04em;
      text-decoration: none;
    }
    /* Removed department entries */
    .brkrm-dept-deleted {
      display: block;
      color: #aaa;
      cursor: not-allowed;
      text-decoration: line-through;
      padding: 2px 0;
      font-size: 12px;
    }
    .brkrm-dept-deleted::after {
      content: ' [REMOVED]';
      font-size: 9px;
      color: #c80000;
      letter-spacing: 0.04em;
      text-decoration: none;
    }
    /* Hero portlet typography (preserves the Special Elite mood) */
    .brkrm-mark {
      font-family: 'Special Elite', monospace;
      font-size: 10px;
      letter-spacing: 0.14em;
      color: #c80000;
      text-transform: uppercase;
      margin: 0 0 10px;
    }
    .brkrm-lede {
      font-family: 'Special Elite', monospace;
      font-size: 14px;
      line-height: 1.6;
      color: #2a3a55;
      margin: 0;
    }
    /* Inline policy stamp (red rectangle) */
    .brkrm-stamp {
      display: inline-block;
      background: #c80000;
      color: #fff;
      font-family: 'Special Elite', monospace;
      font-size: 9px;
      padding: 1px 6px;
      letter-spacing: 0.08em;
      margin-left: 6px;
      vertical-align: middle;
      transform: rotate(-1deg);
    }
    /* Fully-redacted policy block */
    .brkrm-redacted-block {
      background: rgba(200, 0, 0, 0.05);
      border-left: 3px solid #c80000;
      padding-left: 10px;
    }
    /* Handwritten note overlay */
    .brkrm-handwritten {
      display: inline-block;
      font-family: 'Caveat', cursive;
      font-size: 16px;
      color: #cc0099;
      transform: rotate(-1deg);
      margin-left: 4px;
    }
    /* Footer struck-through bits */
    .brkrm-footer s { opacity: 0.5; }
    /* Corporate-style buttons (in case os-btn-* aren't defined globally) */
    .brkrm-btn-primary {
      display: inline-block;
      background: #1d4d8b;
      color: #fff !important;
      font-family: Tahoma, sans-serif;
      font-size: 12px;
      padding: 6px 14px;
      border: 1px solid #0e2d5a;
      text-decoration: none !important;
      box-shadow: 1px 1px 0 #0e2d5a;
      margin-right: 6px;
    }
    .brkrm-btn-primary:hover { background: #266ab8; }
    .brkrm-btn-secondary {
      display: inline-block;
      background: #d4d0c8;
      color: #000 !important;
      font-family: Tahoma, sans-serif;
      font-size: 12px;
      padding: 6px 14px;
      border: 1px solid #808080;
      text-decoration: none !important;
      box-shadow: 1px 1px 0 #808080;
      margin-right: 6px;
    }
    .brkrm-btn-secondary:hover { background: #e0dcd2; }
  </style>

</OldWebLayout>
