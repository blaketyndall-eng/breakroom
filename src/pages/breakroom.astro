---
import OldWebLayout from '@/layouts/OldWebLayout.astro';
import TableBox from '@/components/oldweb/TableBox.astro';
import AuthPanel from '@/components/auth/AuthPanel';
---
<OldWebLayout title="A bunch of bull sh*t, right?" section="breakroom">
  <section class="hero-grid">
    <div>
      <p class="breakroom-mark">BRKRM / employee resources / corrupted</p>
      <h1>A bunch of bull sh*t, right?</h1>
      <p class="lede">This is the conversation with the coworker who knows the same thing you know. The page still functions. It just stopped respecting the company.</p>
      <div class="status-strip"><span>OmniShift Internal</span><span>rogue edits detected</span><span>clock 1:47</span><span>breakroom access pending</span></div>
      <p><a class="old-button" href="/signup">Sign up for whatever this is</a> <a class="old-button" href="/portal">Employee file</a></p>
    </div>
    <AuthPanel client:load compact redirectTo="/portal" />
  </section>

  <div class="grid-3">
    <TableBox title="Employee Resources">
      <p><a href="/portal">View assigned employee file</a></p>
      <p><a href="/clock-out">Clock Out</a></p>
      <p><a href="/house-rules">House Rules</a></p>
    </TableBox>
    <TableBox title="Unauthorized Room Links">
      <p><a href="/after-hours">After Hours</a></p>
      <p><a href="/lost-found">Lost & Found</a></p>
      <p><a href="/newsstand">3AM Edition</a></p>
    </TableBox>
    <TableBox title="Management Notice">
      <p>AI leadership confirms the room is aligned with business outcomes. No one knows what that means.</p>
      <p class="red-stamp">Do not thank the room.</p>
    </TableBox>
  </div>
</OldWebLayout>
