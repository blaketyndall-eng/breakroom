---
type EvidenceItem = {
  name: string;
  detail: string;
  href?: string;
  code?: string;
};

interface Props {
  title: string;
  items: EvidenceItem[];
}

const { title, items } = Astro.props;
---

<section class="old-shell evidence-grid-shell">
  <div class="old-header">{title}</div>
  <div class="old-body evidence-grid">
    {items.map((item, index) => (
      <article class="evidence-card">
        <div class="evidence-photo stripe">EVIDENCE {String(index + 1).padStart(2, '0')}</div>
        <p class="evidence-code">{item.code ?? `BRKRM-${String(index + 147).padStart(3, '0')}`}</p>
        <h3>{item.href ? <a href={item.href}>{item.name}</a> : item.name}</h3>
        <p>{item.detail}</p>
      </article>
    ))}
  </div>
</section>
