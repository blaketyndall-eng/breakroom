---
/**
 * OmniWindow.astro
 * --------------------------------------------------------------------------
 * Win2K-style window frame for OmniShift content sections. Drop it
 * around any block of content to give it the work-computer treatment.
 *
 * Example:
 *   <OmniWindow title="Employee File" icon="📁" status="Read-only">
 *     <p>Field 1: ...</p>
 *   </OmniWindow>
 *
 * Visual is mostly self-contained; uses the Tahoma stack and the same
 * Win2K gradient as OmniShiftBrowser so the chrome feels consistent.
 */

interface Props {
  /** Title bar label. */
  title: string;
  /** Optional icon character/emoji shown in the title bar. */
  icon?: string;
  /** Render the greyed-out inactive title bar variant. */
  inactive?: boolean;
  /** Optional Win2K-style status bar text below the body. */
  status?: string;
}

const {
  title,
  icon = '⊞',  // ⊞
  inactive = false,
  status,
} = Astro.props;
---
<section class={`omw ${inactive ? 'omw-inactive' : ''}`}>
  <header class="omw-titlebar">
    <span class="omw-icon" aria-hidden="true">{icon}</span>
    <span class="omw-title">{title}</span>
    <span class="omw-controls" aria-hidden="true">
      <button class="omw-wbtn" tabindex="-1" aria-label="Minimize">_</button>
      <button class="omw-wbtn" tabindex="-1" aria-label="Maximize">▢</button>
      <button class="omw-wbtn omw-wbtn-close" tabindex="-1" aria-label="Close">×</button>
    </span>
  </header>
  <div class="omw-body">
    <slot />
  </div>
  {status && <footer class="omw-status">{status}</footer>}
</section>

<style>
  .omw {
    background: #d4d0c8;
    border-top: 1px solid #ffffff;
    border-left: 1px solid #ffffff;
    border-right: 1px solid #404040;
    border-bottom: 1px solid #404040;
    box-shadow: 1px 1px 0 0 #000;
    font-family: 'Tahoma', 'MS Sans Serif', system-ui, sans-serif;
    font-size: 12px;
    color: #000;
    margin: 0 0 16px;
  }

  .omw-titlebar {
    background: linear-gradient(90deg, #0a246a 0%, #3a6ea5 100%);
    color: #ffffff;
    padding: 0 4px 0 6px;
    display: flex;
    align-items: center;
    height: 22px;
    font-weight: 700;
    font-size: 11px;
    user-select: none;
  }
  .omw-inactive .omw-titlebar {
    background: linear-gradient(90deg, #7b7b7b 0%, #b5b5b5 100%);
    color: #d4d0c8;
  }
  .omw-icon {
    margin-right: 6px;
    font-size: 14px;
    line-height: 1;
    color: #ffd76b;
  }
  .omw-inactive .omw-icon {
    color: #d4d0c8;
  }
  .omw-title {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.4);
  }
  .omw-inactive .omw-title {
    text-shadow: none;
  }
  .omw-controls {
    display: flex;
    gap: 2px;
  }
  .omw-wbtn {
    width: 18px; height: 16px;
    background: #d4d0c8;
    border-top: 1px solid #ffffff;
    border-left: 1px solid #ffffff;
    border-right: 1px solid #404040;
    border-bottom: 1px solid #404040;
    color: #000;
    font-family: 'Tahoma', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 700;
    line-height: 1;
    padding: 0 0 2px 0;
    cursor: default;
  }
  .omw-wbtn:active {
    border-top: 1px solid #404040;
    border-left: 1px solid #404040;
    border-right: 1px solid #ffffff;
    border-bottom: 1px solid #ffffff;
  }

  .omw-body {
    background: #ffffff;
    color: #000;
    padding: 12px;
    /* Inset border like Win2K group boxes */
    border-top: 1px solid #404040;
    border-left: 1px solid #404040;
    border-right: 1px solid #ffffff;
    border-bottom: 1px solid #ffffff;
    margin: 2px;
    font-family: 'Tahoma', 'MS Sans Serif', system-ui, sans-serif;
    font-size: 12px;
    line-height: 1.45;
  }

  /* Reset content-text styles inside the window so the wrapper
     enforces the Win2K type stack consistently. */
  .omw-body :global(h1),
  .omw-body :global(h2),
  .omw-body :global(h3) {
    font-family: 'Tahoma', system-ui, sans-serif;
    font-weight: 700;
    color: #1a3060;
    letter-spacing: 0;
  }
  .omw-body :global(a) {
    color: #003399;
  }
  .omw-body :global(a:visited) {
    color: #551a8b;
  }
  .omw-body :global(a:hover) {
    background: #003399;
    color: #ffffff;
    text-decoration: none;
  }

  .omw-status {
    background: #d4d0c8;
    border-top: 1px solid #ffffff;
    padding: 3px 8px;
    font-size: 11px;
    color: #404040;
    font-family: 'Tahoma', system-ui, sans-serif;
    box-shadow: inset 0 1px 0 0 #808080;
  }
</style>
