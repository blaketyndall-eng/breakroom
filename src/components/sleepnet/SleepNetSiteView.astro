---
import FakeAdStrip from '@/components/ads/FakeAdStrip.astro';
import MoreLikeThis from '@/components/sleepnet/MoreLikeThis.astro';
import SleepNetComponentRenderer from '@/components/sleepnet/SleepNetComponentRenderer.astro';
import SleepNetGuestbook from '@/components/sleepnet/SleepNetGuestbook';
import AgentCommentBlock from '@/components/agents/AgentCommentBlock.tsx';
import PassItAround from '@/components/sleepnet/PassItAround';
import { seededGuestbookEntry } from '@/lib/sleepnetGuestbooks';
import type { SleepNetSite } from '@/lib/sleepnetSites';

interface Props {
  site: SleepNetSite;
}

const { site } = Astro.props;
const guestbookComponent = site.components?.find((component) => component.type === 'guestbook');
const seededEntries = guestbookComponent?.type === 'guestbook'
  ? guestbookComponent.entries.map((entry) => seededGuestbookEntry({
      siteSlug: site.slug,
      alias: entry.name,
      message: entry.body,
      timestampLabel: entry.timestampLabel,
      actorType: entry.name.toLowerCase().includes('clerk') || entry.name.toLowerCase().includes('manager') || entry.name.toLowerCase().includes('employee') ? 'agent' : 'seeded_npc',
      agentSlug: entry.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, ''),
      pageType: site.site_type,
    }))
  : [];
---
<section class="sleepnet-site-view">
  <header class="sleepnet-site-header">
    <p class="sleepnet-url">sleepnet://{site.slug}</p>
    <h1>{site.title}</h1>
    {site.tagline && <p class="sleepnet-tagline">{site.tagline}</p>}
    {site.description && <p>{site.description}</p>}
    <div class="sleepnet-meta">
      <span>{site.site_type.replaceAll('_', ' ')}</span>
      <span>{site.neighborhood.replaceAll('_', ' ')}</span>
      <span>{site.reality_status ?? 'indexed_noise'}</span>
    </div>
    <PassItAround client:idle siteSlug={site.slug} />
  </header>

  <FakeAdStrip siteType={site.site_type} factionSlug={site.faction_affinity?.[0]} tags={[site.neighborhood, site.site_type, ...(site.related_object_slugs ?? [])]} limit={3} label="Ads Related By Mistake" />

  <section class="old-shell sleepnet-intro">
    <div class="old-header">Page Sections / Filed Publicly</div>
    <div class="old-body sleepnet-section-grid">
      {site.sections.map((section) => (
        <article class="sleepnet-section">
          <h2>{section.title}</h2>
          <p>{section.body}</p>
        </article>
      ))}
    </div>
  </section>

  {site.components?.length ? (
    <section class="sleepnet-component-grid">
      {site.components.filter((component) => component.type !== 'guestbook').map((component) => <SleepNetComponentRenderer component={component} siteSlug={site.slug} />)}
    </section>
  ) : null}

  <AgentCommentBlock
    client:idle
    targetType="sleepnet_site"
    targetSlug={site.slug}
    trigger="page_visit"
    context={{ siteType: site.site_type, factionSlug: site.faction_affinity?.[0] }}
  />

  <MoreLikeThis site={site} />

  {site.guestbook_enabled !== false && <SleepNetGuestbook client:load siteSlug={site.slug} siteType={site.site_type} seededEntries={seededEntries} />}
</section>
