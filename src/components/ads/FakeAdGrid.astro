---
import FakeAdBlock from '@/components/ads/FakeAdBlock.astro';
import { getFakeAdsForContext, getRandomFakeAds } from '@/lib/fakeAds';
import type { FakeAd } from '@/content/data/fakeAds';

interface Props {
  ads?: FakeAd[];
  siteType?: string;
  factionSlug?: string;
  stuffSlug?: string;
  tags?: string[];
  limit?: number;
  label?: string;
}

const props = Astro.props;
const ads = props.ads ?? (props.siteType || props.factionSlug || props.stuffSlug || props.tags
  ? getFakeAdsForContext({ siteType: props.siteType, factionSlug: props.factionSlug, stuffSlug: props.stuffSlug, tags: props.tags, limit: props.limit ?? 8 })
  : getRandomFakeAds(props.limit ?? 8));
---
<section class="fake-ad-grid-wrap" aria-label={props.label ?? 'Fake ad grid'}>
  <div class="fake-ad-strip-header">{props.label ?? 'Directory Sponsors / Unverified'}</div>
  <div class="fake-ad-grid">
    {ads.map((ad) => <FakeAdBlock ad={ad} />)}
  </div>
</section>
