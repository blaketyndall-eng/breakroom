---
import '../styles/global.css';
import OldHeader from '@/components/oldweb/OldHeader.astro';
import OmniShiftBrowser from '@/components/chrome/OmniShiftBrowser.astro';
import OmniShiftTaskbar from '@/components/chrome/OmniShiftTaskbar.astro';
import VoidSignalBrowser from '@/components/chrome/VoidSignalBrowser.astro';
import VoidSignalTaskbar from '@/components/chrome/VoidSignalTaskbar.astro';
import AnonymousBar from '@/components/chrome/AnonymousBar.astro';
import { worldForSection, chromeFor, type World } from '@/lib/worldMap';

interface Props {
  title?: string;
  section?: string;
  description?: string;
  level?: 1 | 2 | 3 | 4;
  /**
   * Optional explicit world override. Most pages should leave this
   * undefined and let `worldForSection(section)` decide. Use only when
   * a page's visual section and its world citizenship intentionally
   * diverge (rare).
   */
  world?: World;
}

const {
  title = 'The Breakroom',
  section = 'breakroom',
  description = 'After-hours internet hidden inside a fake company.',
  level,
  world: worldOverride,
} = Astro.props;

const world = worldOverride ?? worldForSection(section);
const chromeMode = chromeFor(section);
const currentPath = Astro.url.pathname;
---
<!doctype html>
<html
  lang="en"
  data-site-mode="3AM"
  data-world={world}
  data-chrome-mode={chromeMode}
  data-clock-state="anonymous"
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!--
      Pre-paint hydrator. Reads shift_status from localStorage and rewrites
      data-clock-state on <html> BEFORE first paint, so chrome CSS can key
      off the attribute with zero flash.

      Source of truth: src/lib/localSession.ts
        LOCAL_PROFILE_KEY = 'breakroom.omnishift.profile'
        LOCAL_SHIFT_KEY   = 'breakroom.omnishift.shift'
        LocalShiftStatus  = 'on_shift' | 'clocked_out' | 'still_out'
    -->
    <script is:inline>
      (function () {
        try {
          var profileRaw = localStorage.getItem('breakroom.omnishift.profile');
          var shiftRaw = localStorage.getItem('breakroom.omnishift.shift');
          var state = 'anonymous';
          if (profileRaw) {
            var m = profileRaw.match(/"shift_status":"(on_shift|clocked_out|still_out)"/);
            if (m) state = m[1];
          } else if (shiftRaw === 'on_shift' || shiftRaw === 'clocked_out' || shiftRaw === 'still_out') {
            state = shiftRaw;
          }
          document.documentElement.setAttribute('data-clock-state', state);
        } catch (_) {
          /* leave default 'anonymous' */
        }
      })();
    </script>

    <!--
      Foundation chrome layout rules. F6 will extract these to a
      dedicated chrome.css file. For now they live inline so the chrome
      ships with the layout in one commit.
    -->
    <style is:global>
      /* Body padding compensates for fixed chrome at top + bottom. */
      html[data-chrome-mode="desktop"] body {
        padding-top: 50px;
        padding-bottom: 32px;
      }
      html[data-chrome-mode="desktop"][data-clock-state="anonymous"] body {
        padding-top: 32px;
        padding-bottom: 0;
      }
      html[data-chrome-mode="desktop"][data-world="neutral"]:not([data-clock-state="anonymous"]) body {
        padding-top: 0;
        padding-bottom: 0;
      }
      html[data-chrome-mode="pocket"] body,
      html[data-chrome-mode="suppressed"] body {
        padding-top: 0;
        padding-bottom: 0;
      }

      /* Auth-state chrome visibility:
         anonymous → AnonymousBar visible, world bars hidden
         logged in → world bars visible, AnonymousBar hidden
      */
      html[data-clock-state="anonymous"] .osb,
      html[data-clock-state="anonymous"] .vsb,
      html[data-clock-state="anonymous"] .ost,
      html[data-clock-state="anonymous"] .vst {
        display: none !important;
      }
      html:not([data-clock-state="anonymous"]) .ab {
        display: none !important;
      }
    </style>
  </head>
  <body class="scanlines grain" data-section={section} {...(level ? { 'data-level': String(level) } : {})}>
    {chromeMode === 'desktop' && world === 'omnishift' && (
      <>
        <OmniShiftBrowser title={title} currentPath={currentPath} />
        <OmniShiftTaskbar />
        <AnonymousBar />
      </>
    )}
    {chromeMode === 'desktop' && world === 'voidsignal' && (
      <>
        <VoidSignalBrowser currentPath={currentPath} />
        <VoidSignalTaskbar />
        <AnonymousBar />
      </>
    )}
    {chromeMode === 'desktop' && world === 'neutral' && (
      <AnonymousBar />
    )}

    <OldHeader />
    <main>
      <slot />
    </main>
    <footer class="container" style="padding: 24px 0 48px; font-family: var(--type-mono); font-size: 11px; color: #5a513f;">
      <div class="status-strip">
        <span>best viewed after work</span>
        <span>clock stuck at 1:47</span>
        <span>visitor <b class="visitor-counter">18439</b></span>
        <span><a href="/staff-only">staff only</a></span>
      </div>
    </footer>
  </body>
</html>
