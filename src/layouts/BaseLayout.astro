---
import '../styles/global.css';
import OldHeader from '@/components/oldweb/OldHeader.astro';
import VoidLinkBar from '@/components/oldweb/VoidLinkBar.astro';
import OmniShiftBrowser from '@/components/chrome/OmniShiftBrowser.astro';
import OmniShiftTaskbar from '@/components/chrome/OmniShiftTaskbar.astro';
import VoidSignalBrowser from '@/components/chrome/VoidSignalBrowser.astro';
import VoidSignalTaskbar from '@/components/chrome/VoidSignalTaskbar.astro';
import AnonymousBar from '@/components/chrome/AnonymousBar.astro';
import { worldForSection, chromeFor, type World } from '@/lib/worldMap';

interface Props {
  title?: string;
  section?: string;
  description?: string;
  level?: 1 | 2 | 3 | 4;
  world?: World;
}

const {
  title = 'The Breakroom',
  section = 'breakroom',
  description = 'After-hours internet hidden inside a fake company.',
  level,
  world: worldOverride,
} = Astro.props;

const world = worldOverride ?? worldForSection(section);
const chromeMode = chromeFor(section);
const currentPath = Astro.url.pathname;

/* ----------------------------------------------------------------------- */
/*  Footer helpers                                                         */
/*                                                                         */
/*  Visitor counter and session-hex are deterministic from pathname so     */
/*  every reload of the same page shows the same lie. Counters always end  */
/*  in 147 — same 1:47 anchor as Radio 1:47, the boot dialog, the chaos    */
/*  popups. Hex IDs use the same hash, formatted differently.              */
/* ----------------------------------------------------------------------- */
function djb2(s: string): number {
  let h = 5381;
  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) | 0;
  return Math.abs(h);
}
const pathHash = djb2(currentPath || '/');
const visitorCounter = String((pathHash % 900) + 100) + '147'; // 6 digits, ends in 147
const sessionHex = pathHash.toString(16).padStart(8, '0').slice(0, 8).toUpperCase();
const isBreakroom = section === 'breakroom';
---
<!doctype html>
<html
  lang="en"
  data-site-mode="3AM"
  data-world={world}
  data-chrome-mode={chromeMode}
  data-clock-state="anonymous"
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <script is:inline>
      (function () {
        try {
          var profileRaw = localStorage.getItem('breakroom.omnishift.profile');
          var shiftRaw = localStorage.getItem('breakroom.omnishift.shift');
          var state = 'anonymous';
          if (profileRaw) {
            var m = profileRaw.match(/"shift_status":"(on_shift|clocked_out|still_out)"/);
            if (m) state = m[1];
          } else if (shiftRaw === 'on_shift' || shiftRaw === 'clocked_out' || shiftRaw === 'still_out') {
            state = shiftRaw;
          }
          document.documentElement.setAttribute('data-clock-state', state);
        } catch (_) { /* leave default 'anonymous' */ }
      })();
    </script>
  </head>
  <body class="scanlines grain" data-section={section} {...(level ? { 'data-level': String(level) } : {})}>
    {chromeMode === 'desktop' && world === 'omnishift' && (
      <>
        <OmniShiftBrowser title={title} currentPath={currentPath} />
        <OmniShiftTaskbar title={title} />
        <AnonymousBar />
      </>
    )}
    {chromeMode === 'desktop' && world === 'voidsignal' && (
      <>
        <VoidSignalBrowser title={title} currentPath={currentPath} />
        <VoidSignalTaskbar title={title} />
        <AnonymousBar />
      </>
    )}
    {chromeMode === 'desktop' && world === 'neutral' && (
      <AnonymousBar />
    )}

    {/* Links bar below the chrome — world-specific.
        OldHeader uses .bookmarks-strip (hidden on VS via chrome.css);
        VoidLinkBar uses .void-bookmarks-strip and only mounts on VS. */}
    <OldHeader />
    {world === 'voidsignal' && <VoidLinkBar />}

    <main>
      <slot />
    </main>

    {/* ---------------------------------------------------------------- */}
    {/*  Global footer — world-aware                                     */}
    {/* ---------------------------------------------------------------- */}
    <footer class={`bm-foot bm-foot--${world}${isBreakroom ? ' bm-foot--cracked' : ''}`}>
      <div class="status-strip">
        {world === 'omnishift' && !isBreakroom && (
          <>
            <span>OmniShift Industries · Internal Use Only</span>
            <span>shift status: logged</span>
            <span>session <b>0x{sessionHex}</b></span>
            <span>visitor #<b class="visitor-counter">{visitorCounter}</b></span>
            <span><a href="/clock-out">clock out</a></span>
          </>
        )}
        {isBreakroom && (
          <>
            <span>OmniShift Industries · <s>Internal Use Only</s></span>
            <span>shift status: <s>logged</s> <span class="bm-foot-redact">unknown</span></span>
            <span>session <b>0x????????</b></span>
            <span>visitor #<b class="visitor-counter">{visitorCounter}</b></span>
            <span class="bm-foot-edit">Last Edit by ████████</span>
          </>
        )}
        {world === 'voidsignal' && (
          <>
            <span>best viewed after work</span>
            <span>clock stuck at 1:47</span>
            <span>visitor <b class="visitor-counter">{visitorCounter}</b></span>
            <span><a href="/staff-only">staff only</a></span>
          </>
        )}
        {world === 'neutral' && (
          <>
            <span>filed but not displayed</span>
            <span>visitor <b class="visitor-counter">{visitorCounter}</b></span>
            <span><a href="/staff-only">staff only</a></span>
          </>
        )}
      </div>
    </footer>

    <style is:global>
      /* World-aware global footer — small, scoped to .bm-foot */
      .bm-foot {
        max-width: 1100px;
        margin: 0 auto;
        padding: 24px 0 48px;
        font-family: var(--type-mono);
        font-size: 11px;
      }
      .bm-foot--voidsignal { color: #5a513f; }
      .bm-foot--omnishift  { color: #2a3a52; }
      .bm-foot--neutral    { color: #5a513f; }
      .bm-foot--cracked    { color: #4a2222; }
      .bm-foot--omnishift .status-strip a { color: #2a3a52; }
      .bm-foot--cracked .status-strip a   { color: #6a3030; }
      .bm-foot-redact {
        display: inline-block;
        background: #1a1a1a;
        color: #f5d135;
        padding: 0 4px;
        font-weight: bold;
        letter-spacing: 0.05em;
      }
      .bm-foot-edit {
        font-style: italic;
        opacity: 0.65;
      }
      /* Strikethroughs in cracked footer should look like a real pen, not
         a clean line-through. Doubled-up shadow + slight rotation. */
      .bm-foot--cracked s {
        text-decoration: line-through;
        text-decoration-thickness: 1.5px;
        text-decoration-color: #6a3030;
      }
    </style>
  </body>
</html>
